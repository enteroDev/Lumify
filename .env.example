# Vorlage. Auf dem Server kopieren nach ".env" und echte Werte eintragen:
#   cp .env.example .env  &&  nano .env
# Die .env NIEMALS ins Git committen (gehoert in .gitignore).

# Datenbank-Passwoerter (frei waehlbar, lang)
DB_PASSWORD=bitte_langes_db_passwort
DB_ROOT_PASSWORD=bitte_langes_root_passwort

# JWT-Secret der API - LANGER zufaelliger Wert!
# Tipp zum Erzeugen auf dem Server:  openssl rand -base64 48
JWT_SECRET=bitte_langes_zufaelliges_secret
