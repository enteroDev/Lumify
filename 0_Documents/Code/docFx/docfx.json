{
  "metadata": [
    {
      "src": [
        {
          "src": "../../../lumify.api",
          "files": [ "**/*.csproj" ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "*.md", "toc.yml" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "Lumify",
      "_appTitle": "Lumify – Code Documentation",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
